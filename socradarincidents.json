            "output": [
                {
                    "data_path": "action_result.status",
                    "data_type": "string",
                    "example_values": [
                        "success",
                        "failed"
                    ]
                },
                {
                    "data_path": "action_result.message",
                    "data_type": "string"
                },
                {
                    "data_path": "action_result.data.*.alarm_id",
                    "data_type": "string",
                    "contains": [
                        "socradar incident id"
                    ]
                },
                {
                    "data_path": "action_result.data.*.new_severity",
                    "data_type": "string"
                },
                {
                    "data_path": "summary.severity_changed",
                    "data_type": "boolean"
                },
                {
                    "data_path": "action_result.parameter.incident_id",
                    "data_type": "string",
                    "contains": [
                        "socradar incident id"
                    ]
                },
                {
                    "data_path": "action_result.parameter.severity",
                    "data_type": "string"
                },
                {
                    "data_path": "summary.total_objects",
                    "data_type": "numeric"
                },
                {
                    "data_path": "summary.total_objects_successful",
                    "data_type": "numeric"
                }
            ],
            "versions": "EQ(*)"
        }
    ],
